{
  "name": "excalidraw-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Gerenciador de arquivos .excalidraw com editor embarcado",
  "author": "Luis Modesto <luisgmodesto12@gmail.com>",
  "homepage": "https://github.com/LuisFelipeMod/excalidraw_manager",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -s first \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "marked": "^18.0.6",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "sass": "1.51.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.luismodesto.excalidraw-manager",
    "productName": "Excalidraw Manager",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Graphics"
    }
  }
}
